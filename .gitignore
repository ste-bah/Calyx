# ── Claude Code / agent harness ──────────────────────────────────────
.claude/
*.local.json

# ── Secrets (secret manager is source of truth — never commit values) ──────
.env
.env.*
!.env.example
*.env
!*.env.example
secrets/
*.key
*.pem
*.pfx
*.p12
*.token
*.cert
*.crt
credentials.json
service-account*.json
# Tauri updater signing keys (pulled at build time from the vault)
*.updater.key
tauri_updater_signing_key*

# ── Rust / Cargo (Forge math runtime, Aster engine, API) ─────────────
/target/
**/target/
**/*.rs.bk
*.pdb
# Cargo.lock is kept (binary/application — reproducible builds)

# ── Python (FSV harness, test-data acquisition, MI/embedding tooling) ─
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.python-version
*.egg-info/
.eggs/
/build/
/dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ── ML / model weights & embedder lenses (frozen, large — store off-VCS)
*.safetensors
*.gguf
*.onnx
*.pt
*.pth
*.ckpt
*.bin
*.npz
*.npy
models/
checkpoints/
lenses/
# HuggingFace model cache (multi-GB downloads — never commit)
.hf-cache/

# ── Data, datasets, on-disk DB state (Aster storage, ZFS-backed) ─────
data/
/datasets/*
!/datasets/MANIFEST.md
*.aster
*.lsm
*.sst
*.wal
*.parquet
*.arrow
*.duckdb
*.sqlite
*.sqlite3
*.db
db/
storage/
# Keep the Leapable storage engine's Rust source visible even though runtime
# storage directories are ignored everywhere else.
!crates/calyx-leapable/src/engine/storage/
!crates/calyx-leapable/src/engine/storage/**

# ── Logs / temp / scratch (sitrep writes ./tmp) ──────────────────────
*.log
/crates/calyx-forge/tests/autotune_cache_fsv.json
/crates/calyx-forge/tests/promotion_log.jsonl
logs/
tmp/
.tmp/
*.tmp
.cache/
.codex-tmp/

# ── CUDA / GPU build artifacts ───────────────────────────────────────
*.cubin
*.ptx
*.fatbin

# ── Editors / IDE ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# ── OS cruft ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
